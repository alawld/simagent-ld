{
  "name": "subterrans",
  "version": "0.0.1",
  "private": true,
  "description": "A modern ant colony simulation game — spiritual successor to SimAnt (1991)",
  "license": "AGPL-3.0-or-later",
  "author": "Rob Ogilvie",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LightAxe/subterrans.git"
  },
  "homepage": "https://github.com/LightAxe/subterrans#readme",
  "bugs": {
    "url": "https://github.com/LightAxe/subterrans/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:lib": "vite build --config vite.lib.config.ts --base=/demo/play/",
    "preview": "vite preview",
    "sim:episode": "node --experimental-strip-types scripts/run-agent-episode.ts --",
    "sim:export-session": "node --experimental-strip-types scripts/export-agent-session.ts --",
    "sim:jsonl-session": "node --experimental-strip-types scripts/sim-agent-jsonl.ts --",
    "sim:eval-grid": "node --experimental-strip-types scripts/run-eval-grid.ts --",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "verify": "npm run lint && npm run typecheck && bash scripts/check-sim-boundary.sh && bash scripts/check-asset-paths.sh && npm run test"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.0",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.2",
    "typescript": "~5.9.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}

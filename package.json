    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}

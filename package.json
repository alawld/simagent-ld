{
  "name": "subterrans",
  "version": "0.0.1",
  "private": true,
  "description": "A modern ant colony simulation game — spiritual successor to SimAnt (1991)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "verify": "npm run lint && npm run typecheck && bash scripts/check-sim-boundary.sh && npm run test"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.0",
    "jiti": "^2.6.1",
    "typescript": "~5.9.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}

{
  "name": "subterrans",
  "version": "0.0.1",
  "private": true,
  "description": "A modern ant colony simulation game — spiritual successor to SimAnt (1991)",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
